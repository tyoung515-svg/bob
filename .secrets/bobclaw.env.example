# BoB — environment configuration
#
# Copy this file to `bobclaw.env` (same folder) and fill in your values, then
# run `python scripts/gen_secrets.py` to generate the auth secrets automatically.
# The guided setup flow (README / AGENTS-SETUP.md) does all of this for you.
#
# Every key below is read by one of the config modules (core / gateway / pipeline).
# Advanced tuning knobs (COUNCIL_*, RESEARCH_*, BUILD_*, PROFILE_*, MEMORY_* internals)
# all have sane defaults in code and are omitted here — set them only to override.

# ── Auth / secrets ────────────────────────────────────────
# Generated by scripts/gen_secrets.py. BOBCLAW_SECRET signs JWTs AND keys the
# gateway->core scope vouch; TOTP_SECRET seeds 2FA.
BOBCLAW_SECRET=change-me-run-gen_secrets
TOTP_SECRET=
# Admin password. gen_secrets.py stores ONLY the bcrypt hash here and prints the
# plaintext once. To set a plaintext password yourself instead, use BOBCLAW_PASSWORD
# (less secure — it is then stored at rest); the hash is preferred when both are set.
BOBCLAW_PASSWORD_HASH=
BOBCLAW_PASSWORD=

# ── Database ──────────────────────────────────────────────
# The setup flow generates a strong POSTGRES_PASSWORD and writes the matching URL
# here. docker-compose reads POSTGRES_PASSWORD for the postgres container.
POSTGRES_PASSWORD=bobclaw
POSTGRES_URL=postgresql://bobclaw:bobclaw@localhost:5432/bobclaw

# ── Server (loopback by default — see SECURITY.md) ────────
BOBCLAW_CORE_HOST=127.0.0.1
BOBCLAW_CORE_PORT=7825
BOBCLAW_GATEWAY_HOST=127.0.0.1
BOBCLAW_GATEWAY_PORT=7826
# Claude build pipeline service (separate process):
HOST=127.0.0.1
PORT=7823
# Where the gateway finds the upstream services:
CORE_URL=http://127.0.0.1:7825
CLAUDE_PIPELINE_URL=http://127.0.0.1:7823

# ── Faces / identity ──────────────────────────────────────
# Tell every face it's running inside BoB (its name / role / backend) so it never claims it
# can't see its deployment. The CODE default is off (byte-identical); this install opts IN.
# Set false for a bare model with no BoB-identity preamble.
BOB_IDENTITY_ENABLED=true

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Local model backends (optional) ───────────────────────
OLLAMA_URL=http://localhost:11434
LMSTUDIO_URL=http://localhost:1234
PREFERRED_LOCAL_MODEL=gemma-4-27b

# ── Anthropic (Claude API) ────────────────────────────────
# Model IDs: https://platform.claude.com/docs/en/about-claude/models/overview
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-5

# ── Google (Gemini REST API) ──────────────────────────────
GOOGLE_API_KEY=AIza...
# Set these to your account's current Gemini model IDs:
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_PRO_MODEL=gemini-3.1-pro-preview
GEMINI_DEEP_RESEARCH_MODEL=gemini-3.1-pro-preview

# ── DeepSeek (OpenAI-compatible) ──────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash          # set to your provider's current model ID

# ── Z.AI / GLM (OpenAI-compatible) ────────────────────────
# Default base targets the GLM Coding Plan endpoint; use api/paas/v4 for pay-as-you-go.
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-5.2                         # set to your provider's current model ID

# ── Kimi (Moonshot, OpenAI-compatible) ────────────────────
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.7-code                 # set to your provider's current model ID
# Kimi Platform (pay-as-you-go fallback):
MOONSHOT_API_KEY=
KIMI_PLATFORM_BASE_URL=https://api.moonshot.cn/v1
KIMI_PLATFORM_MODEL=kimi-k2.6             # set to your provider's current model ID

# ── MiniMax (OpenAI-compatible) ───────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M3                  # set to your provider's current model ID

# ── Local research head (self-hosted llama.cpp, no key) ───
QWEN_RESEARCH_BASE_URL=http://127.0.0.1:8091/v1
QWEN_RESEARCH_MODEL=qwen3.6-35b-a3b       # whatever local model you serve
QWEN_RESEARCH_API_KEY=

# ── CLI backends (your own subscription — NO API key here) ─
# These run each vendor's official CLI under your own login. Leave the *_CLI_PATH
# blank to resolve the CLI on PATH. See COMPLIANCE.md.
CC_CLI_PATH=          # Anthropic `claude` (run `claude setup-token` for headless auth)
CODEX_CLI_PATH=       # OpenAI `codex` (routes through a local LiteLLM proxy)
KIMI_CLI_PATH=        # Kimi CLI (membership login via `kimi login`)
AGY_CLI_PATH=         # Antigravity `agy` CLI (Google login)
LITELLM_BASE_URL=http://127.0.0.1:4000

# ── Memory module (optional; default OFF) ─────────────────
MEMORY_ENABLED=false
MEMORY_L1_EXTRACTION_ENABLED=false
# Default-on whenever memory is enabled: every BoB memory writer must hold the
# same-machine Qdrant family fence. Leave this true (or unset); false with
# MEMORY_ENABLED=true refuses core startup rather than allowing an unfenced writer.
# Touch it only to make that deliberate configuration-refusal check explicit.
MEMORY_WRITE_FENCE_ENABLED=true
MEMORY_QDRANT_URL=http://127.0.0.1:6353

# ── Feature flags (opt-in; default OFF) ───────────────────
# When true, an approved cc_edit diff is applied via core-direct `git apply`.
CC_EDIT_APPLY_ENABLED=false
# When true, profiles carrying a schedule.cron may run unattended.
PROFILE_SCHEDULE_ENABLED=false

# ── Build/verify sandbox ──────────────────────────────────
# docker (force container; default, fail-closed) | subprocess (host; TRUSTED models only)
# | auto (docker if available, else host + warning). The verify gate runs LLM-written code,
# so keep this at "docker" unless you fully trust the model output.
BUILD_SANDBOX=docker

# ── OpenCode workers (optional) ───────────────────────────
# Comma-separated host:port:workspace_dir triples, e.g. localhost:7900:/path/to/repo
OPENCODE_INSTANCES=

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
